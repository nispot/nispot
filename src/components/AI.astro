---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const monetateFeatures = t('ai.monetate_features');
const featureChips = monetateFeatures
  .split('·')
  .map((feature) => feature.trim())
  .filter(Boolean);

/** Alineado con imágenes del sitio: rgb(18, 116, 126) */
const teal = '#12747E';
const tealDeep = '#0D4F57';
const tealAccent = '#7DD3CE';
---

<section id='ai' class='relative overflow-hidden bg-gradient-to-b from-black-900 via-black-800 to-black-900 px-4 sm:px-6 md:px-8 lg:px-10'>
  <div class='absolute inset-0 opacity-20'>
    <div class='absolute top-20 left-10 w-72 h-72 bg-brand rounded-full blur-[128px]'></div>
    <div class='absolute bottom-20 right-10 w-96 h-96 bg-[#12747E] rounded-full blur-[128px]'></div>
  </div>
  <div class='absolute inset-0 pointer-events-none opacity-30'>
    <div
      class='absolute inset-0'
      style={`background:
        radial-gradient(80% 55% at 50% 8%, rgba(18, 116, 126, 0.18) 0%, rgba(18, 116, 126, 0) 70%),
        radial-gradient(60% 35% at 50% 100%, rgba(251, 88, 28, 0.10) 0%, rgba(251, 88, 28, 0) 75%);`}
    ></div>
    <div
      class='absolute inset-0'
      style='background-image:
        linear-gradient(rgba(125, 211, 206, 0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(125, 211, 206, 0.06) 1px, transparent 1px);
        background-size: 56px 56px;
        mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 80%, transparent 100%);'
    ></div>
  </div>

  <div class='relative w-full mx-auto max-w-screen-xl py-16'>
    <div class='flex items-center justify-center gap-4 mb-10'>
      <div class='h-0.5 flex-1 bg-gradient-to-r from-transparent via-black-400/60 to-black-200'></div>
      <div class='w-10 h-10 rounded-full bg-black-800 border-2 border-brand/40 shadow-[0_0_0_1px_rgba(251,88,28,0.15),0_0_20px_rgba(251,88,28,0.12)] flex items-center justify-center'>
        <span class='w-2.5 h-2.5 bg-brand rounded-full shadow-[0_0_8px_rgba(251,88,28,0.55)]'></span>
      </div>
      <div class='h-0.5 flex-1 bg-gradient-to-l from-transparent via-black-400/60 to-black-200'></div>
    </div>
    <div class='text-center mb-12'>
      <h2 class='text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-3 tracking-tight'>
        {t('ai.title')}
      </h2>
      <p class='text-brand text-lg md:text-xl font-medium'>
        {t('ai.subtitle')}
      </p>
    </div>

    <div class='grid md:grid-cols-[1fr_80px_1fr] gap-4 items-center mb-12'>
      <div class='relative group'>
        <div class='absolute -inset-0.5 bg-gradient-to-r from-brand to-[#F97316] rounded-2xl blur opacity-30 group-hover:opacity-75 transition duration-1000'></div>
        <div class='relative bg-black-800/80 backdrop-blur border border-black-600/50 rounded-2xl p-6'>
          <div class='flex items-center gap-3 mb-4'>
            <div class='w-10 h-10 rounded-full bg-gradient-to-br from-brand to-orange-500 flex items-center justify-center'>
              <svg class='w-5 h-5 text-white' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' />
              </svg>
            </div>
            <h3 class='text-white font-mono text-base uppercase tracking-widest'>
              {t('ai.human_label')}
            </h3>
          </div>
          <ul class='space-y-3'>
            <li class='flex items-center gap-3 text-white font-mono'>
              <span class='text-brand font-bold'>01.</span> 
              <span>{t('ai.human_intent')}</span>
            </li>
            <li class='flex items-center gap-3 text-white font-mono'>
              <span class='text-brand font-bold'>02.</span> 
              <span>{t('ai.human_vision')}</span>
            </li>
            <li class='flex items-center gap-3 text-white font-mono'>
              <span class='text-brand font-bold'>03.</span> 
              <span>{t('ai.human_strategy')}</span>
            </li>
          </ul>
        </div>
      </div>

      <div class='flex flex-col items-center justify-center'>
        <div class='relative'>
          <div class='w-14 h-14 rounded-full border-2 border-brand flex items-center justify-center'>
            <svg class='w-7 h-7 text-brand animate-pulse' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
              <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13 10V3L4 14h7v7l9-11h-7z' />
            </svg>
          </div>
          <div class='absolute inset-0 w-14 h-14 rounded-full border border-brand animate-ping opacity-20'></div>
        </div>
      </div>

      <div class='relative group'>
        <div
          class='absolute -inset-0.5 rounded-2xl blur opacity-30 group-hover:opacity-75 transition duration-1000'
          style={`background: linear-gradient(to right, ${teal}, ${tealDeep});`}
        ></div>
        <div class='relative bg-black-800/80 backdrop-blur border border-black-600/50 rounded-2xl p-6'>
          <div class='flex items-center gap-3 mb-4'>
            <div
              class='w-10 h-10 rounded-full flex items-center justify-center'
              style={`background: linear-gradient(to bottom right, ${teal}, ${tealDeep});`}
            >
              <svg class='w-5 h-5 text-white' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z' />
              </svg>
            </div>
            <h3 class='text-white font-mono text-base uppercase tracking-widest'>
              {t('ai.ai_label')}
            </h3>
          </div>
          <ul class='space-y-3'>
            <li class='flex items-center gap-3 text-white font-mono'>
              <span class='font-bold' style={`color: ${tealAccent};`}>01.</span>
              <span>{t('ai.ai_execution')}</span>
            </li>
            <li class='flex items-center gap-3 text-white font-mono'>
              <span class='font-bold' style={`color: ${tealAccent};`}>02.</span>
              <span>{t('ai.ai_output')}</span>
            </li>
            <li class='flex items-center gap-3 text-white font-mono'>
              <span class='font-bold' style={`color: ${tealAccent};`}>03.</span>
              <span>{t('ai.ai_scale')}</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class='mt-14 md:mt-16 space-y-10 md:space-y-12'>
      <div class='relative rounded-2xl border border-black-600/50 bg-gradient-to-br from-black-900/90 via-black-800/50 to-black-900/80 p-8 md:p-10 shadow-[0_24px_80px_-20px_rgba(0,0,0,0.6)]'>
        <div
          class='absolute left-0 top-6 bottom-6 w-1 rounded-full md:top-8 md:bottom-8'
          style={`background: linear-gradient(to bottom, ${teal}, ${tealDeep});`}
        ></div>
        <div class='pl-5 md:pl-7'>
          <div class='flex items-center justify-center gap-4 mb-6 md:justify-start'>
            <div class='h-px flex-1 max-w-[4rem] bg-gradient-to-r from-transparent to-black-400/70 md:hidden'></div>
            <p class='text-black-200 text-xs font-mono uppercase tracking-widest text-center md:text-left'>
              {t('ai.currently_working')}
            </p>
            <div class='h-px flex-1 max-w-[4rem] bg-gradient-to-l from-transparent to-black-400/70 md:hidden'></div>
          </div>
          <div class='text-center md:text-left'>
            <a
              href='https://monetate.com/'
              target='_blank'
              class='inline-block text-3xl md:text-4xl font-bold text-white hover:text-brand transition-all duration-300 hover:scale-[1.02]'
            >
              {t('ai.monetate_name')}
            </a>
            <p class='text-black-200 text-sm mt-2 font-mono uppercase tracking-wider'>
              {t('ai.monetate_role')}
            </p>
            <p class='text-black-100 text-base mt-3 max-w-2xl mx-auto md:mx-0'>
              {t('ai.monetate_description')}
            </p>
            <div class='flex flex-wrap justify-center gap-2 mt-5 md:justify-start'>
              {featureChips.map((feature) => (
                <span
                  class='px-3 py-1 bg-black-800/90 text-black-100 font-mono text-xs rounded-full border border-black-600/80'
                  style={`box-shadow: 0 0 0 1px ${teal}22 inset;`}
                >
                  {feature}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class='grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.15fr)] lg:items-start'>
        <div class='rounded-2xl border border-black-600/50 bg-black-900/40 p-6 md:p-8'>
          <div class='flex items-center gap-3 mb-4'>
            <div
              class='h-8 w-1 shrink-0 rounded-full'
              style={`background: linear-gradient(to bottom, ${teal}, ${tealDeep});`}
            ></div>
            <p class='text-white text-sm font-semibold tracking-tight leading-snug'>
              {t('ai.tools_description')}
            </p>
          </div>
          <p class='text-black-200 text-xs font-mono uppercase tracking-widest'>
            {t('ai.prompt_engineering')}
          </p>
          <div class='mt-4 flex flex-wrap gap-2'>
            <span
              class='px-4 py-2.5 font-mono text-sm rounded-lg border text-white cursor-default'
              style={`border-color: ${teal}66; background: rgba(18, 116, 126, 0.12);`}
            >
              {t('ai.architecture')}
            </span>
            <span
              class='px-4 py-2.5 font-mono text-sm rounded-lg border text-white cursor-default'
              style={`border-color: ${teal}66; background: rgba(18, 116, 126, 0.12);`}
            >
              {t('ai.quality_control')}
            </span>
            <span
              class='px-4 py-2.5 font-mono text-sm rounded-lg border text-white cursor-default'
              style={`border-color: ${teal}66; background: rgba(18, 116, 126, 0.12);`}
            >
              {t('ai.iteration')}
            </span>
          </div>
        </div>

        <div class='rounded-2xl border border-black-600/50 bg-black-800/30 p-6 md:p-8'>
          <div class='mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between'>
            <p class='text-white text-sm font-semibold tracking-tight'>
              {t('ai.tools_expertise')}
            </p>
            <div class='h-px flex-1 bg-gradient-to-r from-[#12747E]/40 to-transparent sm:ml-4 sm:min-w-[3rem]'></div>
          </div>
          <div class='flex flex-wrap gap-2.5'>
            <span
              class='px-4 py-2.5 font-mono text-sm rounded-lg border text-white transition-colors cursor-default'
              style={`border-color: ${teal}66; background: rgba(18, 116, 126, 0.12);`}
            >
              {t('ai.tools_cursor')}
            </span>
            <span
              class='px-4 py-2.5 font-mono text-sm rounded-lg border text-white transition-colors cursor-default'
              style={`border-color: ${teal}66; background: rgba(18, 116, 126, 0.12);`}
            >
              {t('ai.tools_agents')}
            </span>
            <span
              class='px-4 py-2.5 font-mono text-sm rounded-lg border text-white transition-colors cursor-default'
              style={`border-color: ${teal}66; background: rgba(18, 116, 126, 0.12);`}
            >
              {t('ai.tools_skill_agents')}
            </span>
            <span
              class='px-4 py-2.5 font-mono text-sm rounded-lg border text-white cursor-default'
              style={`border-color: ${teal}66; background: rgba(18, 116, 126, 0.12);`}
            >
              {t('ai.tools_opencode')}
            </span>
            <span
              class='px-4 py-2.5 font-mono text-sm rounded-lg border text-white cursor-default'
              style={`border-color: ${teal}66; background: rgba(18, 116, 126, 0.12);`}
            >
              {t('ai.tools_claude_code')}
            </span>
            <span
              class='px-4 py-2.5 font-mono text-sm rounded-lg border text-white cursor-default'
              style={`border-color: ${teal}66; background: rgba(18, 116, 126, 0.12);`}
            >
              {t('ai.tools_llms')}
            </span>
          </div>
        </div>
      </div>
    </div>

    <div id='ai-hud-wrap' class='relative mt-14 flex justify-center pointer-events-none select-none'>
      <div
        id='ai-hud-panel'
        class='relative w-[min(94%,660px)] h-36 rounded-2xl border border-black-600/70 bg-gradient-to-b from-black-700/70 to-black-900/90 overflow-hidden shadow-[0_30px_70px_-25px_rgba(0,0,0,0.8)]'
        style={`transform: perspective(900px) rotateX(58deg); box-shadow: 0 0 0 1px ${teal}30 inset, 0 24px 50px -22px rgba(0, 0, 0, 0.85);`}
      >
        <div
          class='absolute inset-0 ai-hud-grid'
          style={`background:
            radial-gradient(80% 120% at 50% 0%, rgba(18, 116, 126, 0.22) 0%, rgba(18, 116, 126, 0) 65%),
            linear-gradient(90deg, rgba(125, 211, 206, 0.10) 1px, transparent 1px),
            linear-gradient(rgba(125, 211, 206, 0.08) 1px, transparent 1px);
            background-size: auto, 34px 34px, 34px 34px;`}
        ></div>
        <div class='absolute left-4 right-4 top-4 h-px bg-gradient-to-r from-transparent via-black-100/70 to-transparent ai-hud-line'></div>
        <div class='absolute left-8 right-8 top-10 h-px bg-gradient-to-r from-transparent via-[#12747E]/60 to-transparent ai-hud-line'></div>
        <div class='absolute left-12 right-12 top-16 h-px bg-gradient-to-r from-transparent via-brand/50 to-transparent ai-hud-line'></div>
      </div>
      <div id='ai-hud-card-left' class='absolute -top-3 left-1/2 -translate-x-[190px] w-12 h-12 rounded-xl border border-[#12747E]/50 bg-black-800/80 shadow-[0_0_0_1px_rgba(18,116,126,0.25)_inset]'></div>
      <div id='ai-hud-card-right' class='absolute -top-5 left-1/2 translate-x-[150px] w-16 h-16 rounded-xl border border-brand/40 bg-black-800/70'></div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const initAiHudAnimation = () => {
    const panel = document.getElementById('ai-hud-panel');
    const wrap = document.getElementById('ai-hud-wrap');
    const cardLeft = document.getElementById('ai-hud-card-left');
    const cardRight = document.getElementById('ai-hud-card-right');
    const lines = gsap.utils.toArray('.ai-hud-line');
    const grid = document.querySelector('.ai-hud-grid');

    if (!panel || !wrap || !cardLeft || !cardRight || !grid || !lines.length) return;

    gsap.set([panel, cardLeft, cardRight], { transformOrigin: '50% 50%' });
    gsap.set([panel, cardLeft, cardRight, ...lines], { willChange: 'transform, opacity' });

    const reveal = gsap.timeline({
      defaults: { ease: 'power2.out' },
      scrollTrigger: undefined,
    });

    reveal
      .fromTo(
        panel,
        { y: 24, opacity: 0, scale: 0.98 },
        { y: 0, opacity: 1, scale: 1, duration: 0.9 }
      )
      .fromTo(
        [cardLeft, cardRight],
        { y: 14, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6, stagger: 0.08 },
        '-=0.55'
      );

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          reveal.play(0);
          observer.disconnect();
        }
      },
      { threshold: 0.2 }
    );
    observer.observe(wrap);

    gsap.to(panel, {
      y: -4,
      duration: 2.8,
      ease: 'sine.inOut',
      yoyo: true,
      repeat: -1,
    });

    gsap.to(cardLeft, {
      y: -6,
      x: -2,
      duration: 2.2,
      ease: 'sine.inOut',
      yoyo: true,
      repeat: -1,
    });

    gsap.to(cardRight, {
      y: -8,
      x: 3,
      duration: 2.6,
      ease: 'sine.inOut',
      yoyo: true,
      repeat: -1,
    });

    gsap.to(lines, {
      opacity: 0.45,
      duration: 1.5,
      stagger: 0.2,
      ease: 'sine.inOut',
      yoyo: true,
      repeat: -1,
    });

    gsap.to(grid, {
      backgroundPosition: '20px 12px, 20px 0px, 0px 12px',
      duration: 12,
      ease: 'none',
      repeat: -1,
    });
  };

  document.addEventListener('astro:page-load', initAiHudAnimation, { once: true });
  if (document.readyState !== 'loading') {
    initAiHudAnimation();
  }
</script>
