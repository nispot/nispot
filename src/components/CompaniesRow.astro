<style>
  .marquee {
    display: flex;
    overflow: hidden;
    animation: marquee 200s linear infinite;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-100%);
    }
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const marquee = document.querySelector('.marquee');
    const marqueeItems = marquee?.innerHTML || '';

    // Clonar los elementos una vez para crear el efecto infinito
    marquee!.innerHTML +=
      marqueeItems + marqueeItems + marqueeItems + marqueeItems + marqueeItems;

    // Ajustar el ancho mínimo del contenedor dinámicamente
    const itemCount = marquee!.children.length;
    (marquee as HTMLElement).style.minWidth = `${itemCount * 200}px`;
  });
</script>
