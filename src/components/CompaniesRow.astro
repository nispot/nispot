---
type Company = {
  name: string;
  logo: string;
  url: string;
  position: string;
  duration: string;
  location: string;
  summary: string;
  height: number;
};

type MarqueePair = {
  kind: 'pair';
  consultant: Company;
  client: Company;
  position: string;
  duration: string;
  location: string;
  /** Texto único para la tarjeta: experiencia + relación consultora → cliente */
  narrative: string;
};

type MarqueeSingle = {
  kind: 'single';
  company: Company;
};

type MarqueeGroup = MarqueePair | MarqueeSingle;

