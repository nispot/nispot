const imgBottom = (name: string, height: number) => {
  if (name === 'AccelOne') return 14;
  if (name === 'Claro Video') return 12;
  if (name === 'Telecom Argentina') return 6;
  if (height < 20) return 10;
  return 0;
};

const pairPayload = (g: MarqueeGroup) => {
  if (g.kind === 'pair') {
    return JSON.stringify({
      kind: 'pair',
      clientName: g.client.name,
      consultantName: g.consultant.name,
      position: g.position,
      duration: g.duration,
      location: g.location,
      narrative: g.narrative,
    });
  }
  return JSON.stringify({
    kind: 'single',
    name: g.company.name,
    position: g.company.position,
    duration: g.company.duration,
    location: g.company.location,
    narrative: g.company.summary,
  });
};
---

<section class='bg-black-900 mt-10 mb-10 overflow-hidden py-2'>
  <div class='marquee-container overflow-hidden relative'>
    <div class='marquee flex items-center' id='companies-marquee'>
      {[0, 1].map(() => (
        <>
          {marqueeGroups.map((group) => (
            <>
              <div
                class='company-pair flex flex-shrink-0 items-center gap-2 sm:gap-3 px-2 sm:px-4 rounded-lg transition-opacity duration-300'
                data-pair={pairPayload(group)}
              >
                {group.kind === 'pair' ? (
                  <>
                    <a
                      href={group.consultant.url}
                      target='_blank'
                      rel='noopener noreferrer'
                      class='company-logo-pair flex-shrink-0 py-2 opacity-70 transition-opacity duration-300 cursor-pointer'
                    >
                      <img
                        src={group.consultant.logo}
                        alt={group.consultant.name}
                        class='w-auto object-contain'
                        style={`height: ${group.consultant.height}px; margin-bottom: ${imgBottom(group.consultant.name, group.consultant.height)}px;`}
                      />
                    </a>
                    <span
                      class='company-pair-arrow flex flex-shrink-0 items-center text-black-400 opacity-50'
                      aria-hidden='true'
                    >
                      <svg
                        class='w-4 h-4 sm:w-[18px] sm:h-[18px]'
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2'
                        stroke-linecap='round'
                        stroke-linejoin='round'
                      >
                        <path d='M5 12h14M14 8l6 4-6 4' />
                      </svg>
                    </span>
                    <a
                      href={group.client.url}
                      target='_blank'
                      rel='noopener noreferrer'
                      class='company-logo-pair flex-shrink-0 py-2 opacity-70 transition-opacity duration-300 cursor-pointer'
                    >
                      <img
                        src={group.client.logo}
                        alt={group.client.name}
                        class='w-auto object-contain'
                        style={`height: ${group.client.height}px; margin-bottom: ${imgBottom(group.client.name, group.client.height)}px;`}
                      />
                    </a>
                  </>
                ) : (
                  <a
                    href={group.company.url}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='company-logo-pair flex-shrink-0 py-2 opacity-70 transition-opacity duration-300 cursor-pointer'
                  >
                    <img
                      src={group.company.logo}
                      alt={group.company.name}
                      class='w-auto object-contain'
                      style={`height: ${group.company.height}px; margin-bottom: ${imgBottom(group.company.name, group.company.height)}px;`}
                    />
                  </a>
                )}
              </div>
              <span
                class='flex flex-shrink-0 items-center justify-center px-2 sm:px-4 opacity-45'
                aria-hidden='true'
              >
                <img
                  src='/images/companies/separator.svg'
                  alt=''
                  width='34'
                  height='20'
                  class='h-4 w-auto sm:h-5'
                />
              </span>
            </>
          ))}
        </>
      ))}
    </div>
  </div>

  <div
    id='company-card'
    class='fixed z-50 hidden bg-gray-900/80 backdrop-blur-md border border-gray-700/50 rounded-2xl p-6 shadow-2xl w-96 max-w-[calc(100vw-2rem)]'
    style='pointer-events: none; box-shadow: 0 0 30px -5px rgba(125, 211, 206, 0.15), 0 0 60px -10px rgba(125, 211, 206, 0.1);'
  >
    <div class='flex items-start gap-4 mb-2'>
      <div class='flex-1 min-w-0'>
        <h3
          class='text-brand font-bold text-xl mb-1'
          style='text-shadow: 0 0 15px rgba(255,255,255,0.8), 0 0 30px rgba(255,255,255,0.4);'
          id='card-company'
        />
        <p
          class='text-gray-400 text-sm leading-snug mb-2 hidden'
          id='card-via'
        />
        <p
          class='font-medium text-sm'
          style='color: #2E7D76; text-shadow: 0 0 15px rgba(255,255,255,0.8), 0 0 30px rgba(255,255,255,0.4);'
          id='card-position'
        />
      </div>
    </div>
    <div class='text-gray-400 text-xs mb-3 flex items-center gap-2'>
      <svg class='w-4 h-4 shrink-0' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
        <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' />
      </svg>
      <span id='card-duration' />
    </div>
    <div class='text-gray-500 text-xs mb-3 flex items-center gap-2'>
      <svg class='w-4 h-4 shrink-0' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
        <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z' />
        <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 11a3 3 0 11-6 0 3 3 0 016 0z' />
      </svg>
      <span id='card-location' />
    </div>
    <div class='border-t border-gray-700 pt-3 mt-1'>
      <p class='text-gray-300 text-sm leading-relaxed' id='card-summary' />
    </div>
  </div>
</section>

<style>
  .marquee-container {
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee {
    animation: scroll 40s linear infinite;
    width: fit-content;
  }

  .marquee:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .company-pair:hover .company-logo-pair,
  .company-pair:hover .company-pair-arrow,
  .company-pair:focus-within .company-logo-pair,
  .company-pair:focus-within .company-pair-arrow {
    opacity: 1;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pairs = document.querySelectorAll('.company-pair');
    const card = document.getElementById('company-card');
    const cardCompany = document.getElementById('card-company');
    const cardVia = document.getElementById('card-via');
    const cardPosition = document.getElementById('card-position');
    const cardDuration = document.getElementById('card-duration');
    const cardLocation = document.getElementById('card-location');
    const cardSummary = document.getElementById('card-summary');
    const marqueeContainer = document.querySelector('.marquee-container') as HTMLElement;

    if (!card || pairs.length === 0 || !marqueeContainer) return;

    const CARD_HEIGHT = 300;
    const MARGIN = 4;

    let hideTimeout: ReturnType<typeof setTimeout>;

    type PairPayload =
      | {
          kind: 'pair';
          clientName: string;
          consultantName: string;
          position: string;
          duration: string;
          location: string;
          narrative: string;
        }
      | {
          kind: 'single';
          name: string;
          position: string;
          duration: string;
          location: string;
          narrative: string;
        };

    const fillCard = (data: PairPayload) => {
      if (!cardCompany || !cardVia || !cardPosition || !cardDuration || !cardLocation || !cardSummary)
        return;

      if (data.kind === 'pair') {
        cardCompany.textContent = data.clientName;
        cardVia.textContent = `A través de ${data.consultantName}`;
        cardVia.classList.remove('hidden');
        cardPosition.textContent = data.position;
        cardDuration.textContent = data.duration;
        cardLocation.textContent = data.location;
        cardSummary.textContent = data.narrative;
      } else {
        cardCompany.textContent = data.name;
        cardVia.classList.add('hidden');
        cardVia.textContent = '';
        cardPosition.textContent = data.position;
        cardDuration.textContent = data.duration;
        cardLocation.textContent = data.location;
        cardSummary.textContent = data.narrative;
      }
    };

    const positionCard = (anchor: DOMRect) => {
      const marqueeRect = marqueeContainer.getBoundingClientRect();
      const marqueeTop = marqueeRect.top;
      const marqueeBottom = marqueeRect.bottom;

      const spaceAbove = marqueeTop;
      const spaceBelow = window.innerHeight - marqueeBottom;

      let y: number;
      if (spaceAbove >= CARD_HEIGHT + MARGIN) {
        y = marqueeTop - CARD_HEIGHT - MARGIN + 15;
      } else if (spaceBelow >= CARD_HEIGHT + MARGIN) {
        y = marqueeBottom + MARGIN + 15;
      } else {
        y = Math.max(10, anchor.top - CARD_HEIGHT - 12);
      }

      const elCenter = anchor.left + anchor.width / 2;
      const x = Math.max(20, Math.min(elCenter - 192, window.innerWidth - 404));
      y = Math.min(y, window.innerHeight - CARD_HEIGHT - 10);
      y = Math.max(y, 10);

      card.style.left = `${x}px`;
      card.style.top = `${y}px`;
    };

    const showCardForPair = (pairEl: Element) => {
      const raw = pairEl.getAttribute('data-pair');
      if (!raw) return;
      const data = JSON.parse(raw) as PairPayload;
      fillCard(data);
      positionCard(pairEl.getBoundingClientRect());
      card.classList.remove('hidden');
    };

    const hideCard = () => {
      hideTimeout = setTimeout(() => {
        card.classList.add('hidden');
      }, 200);
    };

    pairs.forEach((pairEl) => {
      pairEl.addEventListener('mouseenter', () => {
        clearTimeout(hideTimeout);
        showCardForPair(pairEl);
      });

      pairEl.addEventListener('mousemove', () => {
        positionCard(pairEl.getBoundingClientRect());
      });

      pairEl.addEventListener('mouseleave', hideCard);

      pairEl.addEventListener('focusin', () => {
        clearTimeout(hideTimeout);
        showCardForPair(pairEl);
      });

      pairEl.addEventListener('focusout', (e) => {
        const next = (e as FocusEvent).relatedTarget as Node | null;
        if (next && pairEl.contains(next)) return;
        hideCard();
      });
    });
  });
</script>
