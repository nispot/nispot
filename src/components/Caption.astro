---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  class='w-full mx-auto max-w-screen-xl grid grid-cols-[25%_75%] mt-10 mb-10'
>
  <div class='flex justify-end'>
    <img src='/images/points.svg' alt='hero' width='70%' />
  </div>
  <div class='w-[90%]'>
    <p
      class='text-lg sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl text-black font-bold m-10 mb-4'
    >
      {t('caption.text')}
    </p>
  </div>
</section>
